APP_NAME=NewsFlow
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./newsflow.db
DATABASE_ECHO=false
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=120
ALGORITHM=HS256
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_HIGH_RISK_MODEL=gpt-4o
LLM_TEMPERATURE_DEFAULT=0.3
LLM_TEMPERATURE_VERIFICATION=0.0
LLM_DAILY_BUDGET_USD=100.0
LLM_PER_PACKET_BUDGET_USD=5.0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PUBLIC=newsflow-public
MINIO_BUCKET_RESTRICTED=newsflow-restricted
ELASTICSEARCH_URL=http://localhost:9200
SOURCE_VAULT_ENCRYPTION_KEY=change-me-source-vault-key-32bytes
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$
